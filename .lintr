linters: linters_with_defaults(
    line_length_linter(100),
    object_usage_linter = NULL,
    object_name_linter = object_name_linter(
      styles = c("snake_case", "symbols"),
      regexes = c(
        snake_case_with_single_dot = "^[a-z][a-z0-9]*(_[a-z0-9]+)*\\.[a-z][a-z0-9]*(_[a-z0-9]+)*$"
      )
    ),
    object_length_linter = object_length_linter(
      60
    ),
    pipe_consistency_linter = pipe_consistency_linter(pipe = "%>%"),
    indentation_linter = indentation_linter(
      hanging_indent_style = "never"
    ),
    return_linter = NULL
  )